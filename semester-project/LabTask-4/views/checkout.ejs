<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - Rivaj</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #f5f5f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }
        .card {
            background: #fff;
            padding: 32px;
            border-radius: 8px;
            box-shadow: 0 2px 16px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 520px;
            text-align: center;
        }
        h1 { color: #7a1f54; margin-bottom: 10px; }
        p { color: #555; }
        .btn {
            display: inline-block;
            margin-top: 18px;
            padding: 10px 18px;
            background: #7a1f54;
            color: #fff;
            text-decoration: none;
            border-radius: 4px;
        }
        .btn:hover { background: #611742; }
    </style>
</head>
<body>
    <div class="card">
        <h1>Checkout</h1>
        <p>This page is protected. Only logged-in users can access checkout.</p>
        <a class="btn" href="/products">Back to Products</a>
    </div>
</body>
</html>
