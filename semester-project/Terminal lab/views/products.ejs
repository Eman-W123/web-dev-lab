<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Products - Rivaj</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="products-page container">
    <div class="account-links account-links--page">
      <%- include('partials/account-links') %>
    </div>
    <div class="products-page__header">
      <h1>Our Products</h1>
      <a class="account-link" href="/cart">View Cart<% if (cartCount > 0) { %> (<%= cartCount %>)<% } %></a>
    </div>
    <div class="filters-section">
      <form class="filters-form" method="GET" action="/products">
        <div class="filter-group">
          <label for="search">Search</label>
          <input id="search" name="search" type="text" value="<%= search %>" placeholder="Search products...">
        </div>
        <div class="filter-group">
          <label for="category">Category</label>
          <select id="category" name="category">
            <option value="">All Categories</option>
            <% categories.forEach(function(cat){ %>
              <option value="<%= cat %>" <%= category===cat? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>
        <div class="filter-group">
          <label for="minPrice">Min Price</label>
          <input id="minPrice" name="minPrice" type="number" value="<%= minPrice %>">
        </div>
        <div class="filter-group">
          <label for="maxPrice">Max Price</label>
          <input id="maxPrice" name="maxPrice" type="number" value="<%= maxPrice %>">
        </div>
        <div class="filter-group">
          <label for="sort">Sort</label>
          <select id="sort" name="sort">
            <option value="name_asc" <%= sort === 'name_asc' ? 'selected' : '' %>>Name (A-Z)</option>
            <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>>Price: Low to High</option>
            <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>Price: High to Low</option>
            <option value="rating_desc" <%= sort === 'rating_desc' ? 'selected' : '' %>>Rating: High to Low</option>
            <option value="stock_desc" <%= sort === 'stock_desc' ? 'selected' : '' %>>Stock: High to Low</option>
          </select>
        </div>
        <button class="filter-btn" type="submit">Apply</button>
        <a class="clear-btn" href="/products">Clear</a>
      </form>
    </div>

    <p class="results-info">Showing <%= products.length %> of <%= totalProducts %> products</p>

    <div class="products-grid">
      <% if (products.length===0) { %>
        <div class="no-products">No products found</div>
      <% } %>
      <% products.forEach(function(product){ %>
        <div class="product-card">
          <div class="product-card__image">
            <img src="<%= product.image %>" alt="<%= product.name %>">
          </div>
          <div class="product-card__body">
            <p class="product-card__category"><%= product.category %></p>
            <h3 class="product-card__name"><%= product.name %></h3>
            <p class="product-card__rating">Rating: <%= product.rating %></p>
            <p class="product-card__price">Rs. <%= product.price %></p>
            <p class="product-card__stock"><%= product.stock >0 ? 'In Stock' : 'Out of Stock' %></p>
            <% if (product.stock > 0) { %>
              <button
                type="button"
                class="btn btn--primary btn--small add-to-cart-btn"
                data-product-id="<%= product._id %>"
                data-product-name="<%= product.name %>">
                Add to Cart
              </button>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>

    <% if (totalPages>1) { %>
      <div class="pagination">
        <% if (currentPage > 1) { %>
          <a href="/products?page=<%= currentPage-1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>&sort=<%= sort %>">← Prev</a>
        <% } else { %>
          <span class="disabled">← Prev</span>
        <% } %>

        <% for(let i=1;i<=totalPages;i++){ %>
          <% if (i===currentPage){ %>
            <span class="active"><%= i %></span>
          <% } else { %>
            <a href="/products?page=<%= i %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>&sort=<%= sort %>"><%= i %></a>
          <% } %>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <a href="/products?page=<%= currentPage+1 %>&search=<%= search %>&category=<%= category %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>&sort=<%= sort %>">Next →</a>
        <% } else { %>
          <span class="disabled">Next →</span>
        <% } %>
      </div>
    <% } %>

  </div>

  <div id="cart-toast" class="cart-toast" hidden></div>

  <script>
    window.RIVAJ_USER = <%- JSON.stringify(!!user) %>;
  </script>
  <script src="/script.js"></script>
</body>
</html>