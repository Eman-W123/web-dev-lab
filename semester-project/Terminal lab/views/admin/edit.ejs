<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Product - Rivaj Admin</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #f5f5f5; }

        .admin-layout { display: flex; min-height: 100vh; }

        .sidebar {
            width: 240px;
            background: #7a1f54;
            color: white;
            padding: 30px 0;
            flex-shrink: 0;
        }

        .sidebar__logo {
            font-size: 22px;
            font-weight: 700;
            padding: 0 24px 30px;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            margin-bottom: 20px;
        }

        .sidebar__nav { list-style: none; }

        .sidebar__nav li a {
            display: block;
            padding: 12px 24px;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            font-size: 14px;
            transition: background 0.2s;
        }

        .sidebar__nav li a:hover,
        .sidebar__nav li a.active {
            background: rgba(255,255,255,0.15);
            color: white;
        }

        .main-content { flex: 1; padding: 30px; }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        .page-header h1 { font-size: 24px; color: #333; }

        .form-card {
            background: white;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            padding: 30px;
            max-width: 600px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #333;
            margin-bottom: 8px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 10px 14px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 14px;
            color: #333;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: #7a1f54;
        }

        .form-group small {
            font-size: 12px;
            color: #888;
            margin-top: 4px;
            display: block;
        }

        .current-image {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 10px;
            padding: 10px;
            background: #f9f9f9;
            border-radius: 4px;
        }

        .current-image img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
        }

        .current-image p {
            font-size: 13px;
            color: #666;
        }

        .btn {
            padding: 10px 24px;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary { background: #7a1f54; color: white; }
        .btn-primary:hover { background: #611742; }
        .btn-secondary { background: #eee; color: #333; }
        .btn-secondary:hover { background: #ddd; }

        .form-actions {
            display: flex;
            gap: 12px;
            margin-top: 10px;
        }

        .required { color: #d9534f; }
    </style>
</head>
<body>

<div class="admin-layout">

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar__logo">Rivaj Admin</div>
        <ul class="sidebar__nav">
            <li><a href="/admin">Dashboard</a></li>
            <li><a href="/admin/add">Add Product</a></li>
            <li><a href="/products">View Store</a></li>
            <li><a href="/">Home</a></li>
        </ul>
    </aside>

    <!-- Main Content -->
    <main class="main-content">

        <div class="page-header">
            <h1>Edit Product</h1>
        </div>

        <div class="form-card">
            <form action="/admin/edit/<%= product._id %>" method="POST" enctype="multipart/form-data">

                <!-- Name -->
                <div class="form-group">
                    <label>Product Name <span class="required">*</span></label>
                    <input
                        type="text"
                        name="name"
                        value="<%= product.name %>"
                        required
                    >
                </div>

                <!-- Category -->
                <div class="form-group">
                    <label>Category <span class="required">*</span></label>
                    <select name="category" required>
                        <option value="">Select Category</option>
                        <option value="Skincare" <%= product.category === 'Skincare' ? 'selected' : '' %>>Skincare</option>
                        <option value="Serums" <%= product.category === 'Serums' ? 'selected' : '' %>>Serums</option>
                        <option value="Makeup" <%= product.category === 'Makeup' ? 'selected' : '' %>>Makeup</option>
                        <option value="Hair Care" <%= product.category === 'Hair Care' ? 'selected' : '' %>>Hair Care</option>
                        <option value="Personal Care" <%= product.category === 'Personal Care' ? 'selected' : '' %>>Personal Care</option>
                    </select>
                </div>

                <!-- Price -->
                <div class="form-group">
                    <label>Price (Rs.) <span class="required">*</span></label>
                    <input
                        type="number"
                        name="price"
                        value="<%= product.price %>"
                        min="0"
                        step="0.01"
                        required
                    >
                </div>

                <!-- Rating -->
                <div class="form-group">
                    <label>Rating <span class="required">*</span></label>
                    <input
                        type="number"
                        name="rating"
                        value="<%= product.rating %>"
                        min="0"
                        max="5"
                        step="0.1"
                        required
                    >
                    <small>Enter a value between 0 and 5</small>
                </div>

                <!-- Stock -->
                <div class="form-group">
                    <label>Stock <span class="required">*</span></label>
                    <input
                        type="number"
                        name="stock"
                        value="<%= product.stock %>"
                        min="0"
                        required
                    >
                </div>

                <!-- Current Image -->
                <div class="form-group">
                    <label>Current Image</label>
                    <% if(product.image) { %>
                        <div class="current-image">
                            <img src="<%= product.image %>" alt="<%= product.name %>">
                            <p>Current image — upload new one to replace it</p>
                        </div>
                    <% } else { %>
                        <p style="font-size:13px; color:#888; margin-bottom:8px;">No image uploaded yet</p>
                    <% } %>

                    <!-- New Image Upload -->
                    <input
                        type="file"
                        name="image"
                        accept="image/*"
                    >
                    <small>Leave empty to keep current image</small>
                </div>

                <!-- Buttons -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="/admin" class="btn btn-secondary">Cancel</a>
                </div>

            </form>
        </div>

    </main>
</div>

</body>
</html>
